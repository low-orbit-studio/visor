{
  "name": "visor",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Low Orbit Studio's shared design system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/low-orbit-studio/visor.git"
  },
  "homepage": "https://visor.loworbit.studio",
  "bugs": {
    "url": "https://github.com/low-orbit-studio/visor/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/theme-engine && npm run build -w packages/tokens && npm run build -w packages/cli && npm run build -w packages/docs",
    "build:tokens": "npm run build -w packages/tokens",
    "pretest": "node packages/docs/scripts/ensure-theme-overlays.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && npm run typecheck --workspaces --if-present",
    "validate": "npx tsx scripts/validate.ts",
    "validate:strict": "npx tsx scripts/validate.ts --strict",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:dev": "npm run dev -w packages/docs",
    "docs:build": "npm run build -w packages/docs",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "husky 2>/dev/null || true",
    "fonts:add": "varlock run -- npx visor fonts add",
    "themes:compute-scales": "npx tsx scripts/compute-primary-scales.ts",
    "previews": "tsx scripts/generate-previews.ts",
    "widgetbook:sync": "bash scripts/sync-widgetbook-widgets.sh",
    "widgetbook:build": "bash scripts/build-widgetbook.sh",
    "widgetbook:dev": "bash -c 'bash scripts/sync-widgetbook-widgets.sh && cd packages/widgetbook && ${FLUTTER:-$HOME/fvm/versions/3.35.5/bin/flutter} pub get && ${FLUTTER:-$HOME/fvm/versions/3.35.5/bin/flutter} pub run build_runner build --delete-conflicting-outputs && ${FLUTTER:-$HOME/fvm/versions/3.35.5/bin/flutter} run -d chrome'"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.59.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@varlock/bitwarden-plugin": "^0.0.5",
    "@vitejs/plugin-react": "^5.2.0",
    "axe-core": "^4.11.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.183.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "varlock": "^0.6.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@conform-to/react": "^1.17.1",
    "@conform-to/zod": "^1.17.1",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "culori": "^4.0.2",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "intl-tel-input": "^26.9.1",
    "react-day-picker": "^9.14.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "zod": "^3.25.76"
  },
  "overrides": {
    "jsdom": "^29.0.2"
  }
}
