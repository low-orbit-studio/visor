{
  "name": "@loworbitstudio/visor",
  "version": "0.7.0",
  "description": "CLI for the Visor design system — add components, hooks, and utilities to your project.",
  "type": "module",
  "bin": {
    "visor": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "npm run build:cli && npm run build:registry && npm run build:manifest",
    "build:registry": "tsx src/generate/build-registry.ts",
    "build:manifest": "tsx src/generate/build-manifest.ts",
    "build:cli": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "visor",
    "design-system",
    "cli",
    "components",
    "react",
    "nextjs",
    "ui-library",
    "typescript",
    "css-modules",
    "accessibility"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/low-orbit-studio/visor.git"
  },
  "homepage": "https://visor.loworbit.studio",
  "bugs": {
    "url": "https://github.com/low-orbit-studio/visor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@babel/parser": "^7.26.0",
    "@loworbitstudio/visor-theme-engine": "^0.4.0",
    "commander": "^13.1.0",
    "diff": "^8.0.4",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
}
