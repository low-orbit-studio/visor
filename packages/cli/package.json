{
  "name": "@loworbitstudio/visor",
  "version": "0.1.0",
  "description": "CLI for the Visor design system — add components, hooks, and utilities to your project.",
  "type": "module",
  "bin": {
    "visor": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "npm run build:cli && npm run build:registry && npm run build:manifest",
    "build:registry": "tsx src/generate/build-registry.ts",
    "build:manifest": "tsx src/generate/build-manifest.ts",
    "build:cli": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "visor",
    "design-system",
    "cli",
    "components"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@loworbitstudio/visor-theme-engine": "^0.1.0",
    "commander": "^13.1.0",
    "diff": "^7.0.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
