{
  "name": "@loworbitstudio/visor-core",
  "version": "0.6.0",
  "description": "Design tokens for the Visor design system — CSS custom properties for theming.",
  "type": "module",
  "main": "./dist/index.css",
  "exports": {
    ".": "./dist/index.css",
    "./css": "./dist/index.css",
    "./tokens": "./dist/tokens.css",
    "./primitives": "./dist/primitives.css",
    "./semantic": "./dist/semantic.css",
    "./themes/blackout": "./dist/themes/blackout.css",
    "./themes/dark": "./dist/themes/dark.css",
    "./themes/light": "./dist/themes/light.css",
    "./themes/modern-minimal": "./dist/themes/modern-minimal.css",
    "./themes/neutral": "./dist/themes/neutral.css",
    "./themes/space": "./dist/themes/space.css",
    "./types": "./src/types.ts",
    "./utilities": "./dist/utilities.css"
  },
  "scripts": {
    "build": "tsx src/generate/generate-css.ts",
    "validate": "tsx src/generate/validate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "files": [
    "dist/",
    "src/types.ts"
  ],
  "keywords": [
    "design-tokens",
    "design-system",
    "visor",
    "css-variables"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/low-orbit-studio/visor.git"
  },
  "homepage": "https://visor.loworbit.studio",
  "bugs": {
    "url": "https://github.com/low-orbit-studio/visor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@loworbitstudio/visor-theme-engine": "^0.4.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
}
