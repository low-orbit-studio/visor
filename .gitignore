venv/

# Playbook (allow project scripts/, ignore playbook scripts)
!/scripts/

# Cloudflare
.wrangler/

# Claude Code — ignore session/runtime data but track committed skills
.claude/agents/
.claude/plans/
.claude/research/
.claude/settings.json
.claude/settings.local.json
.claude/scheduled_tasks.lock
