.claire/

# Testing
coverage/
.nyc_output/
test-results/

# Playwright
playwright-report/
blob-report/

# Claude Code session artifacts (ignore everything in .lo/ except the committed project manifest)
.lo/*
!.lo/project.yaml
*.bak.*

# Git worktrees (lo-swarm / lo-autopilot)
.worktrees/
/worktrees/

# Custom themes (proprietary — not committed to public repo)
custom-themes/

# Theme overlay files (generated by `visor theme sync`)
packages/docs/app/custom-themes.generated.css
packages/docs/lib/theme-config.custom.generated.ts

# Private theme overlay files (generated by scripts/generate-private-themes.mjs)
packages/docs/app/private-themes.generated.css
packages/docs/lib/private-themes.generated.ts

# All custom theme CSS files are generated; stock themes are explicit re-includes
packages/docs/app/*-theme.css
!packages/docs/app/blackout-theme.css
!packages/docs/app/borderless-theme.css
!packages/docs/app/modern-minimal-theme.css
!packages/docs/app/neutral-theme.css
!packages/docs/app/space-theme.css

# Custom theme YAML copies in docs public folder (stock themes re-included)
packages/docs/public/themes/*.visor.yaml
!packages/docs/public/themes/blackout.visor.yaml
!packages/docs/public/themes/borderless.visor.yaml
!packages/docs/public/themes/modern-minimal.visor.yaml
!packages/docs/public/themes/neutral.visor.yaml
!packages/docs/public/themes/space.visor.yaml
.vercel

# Claude Code session artifacts
.env*
